{
  "expo": {
    "name": "FlickTV",
    "slug": "flicktv",
    "version": "1.0.0",
    "scheme": "flicktv",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flicktv.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.flicktv.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow FlickTV to use Face ID for secure login."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001",
      "router": {},
      "eas": {
        "projectId": "8fac759f-61a6-425e-98de-2dfcbb1f75be"
      }
    },
    "owner": "faisalzakariibrahim"
  }
}
